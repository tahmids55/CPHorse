# Copy this file to .env for local development
# Never commit .env to version control

# Your Telegram bot token from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# The public HTTPS URL of your Render service (no trailing slash)
# e.g. https://your-app-name.onrender.com
WEBHOOK_URL=https://your-app-name.onrender.com

# Telegram group chat ID where the bot lives (negative number for groups)
# How to get it: add the bot to the group, send a message, then call
# https://api.telegram.org/bot<BOT_TOKEN>/getUpdates and look for "chat":{"id":-xxxxx}
GROUP_CHAT_ID=-1001234567890

# How often (in minutes) to poll Codeforces for new submissions (default: 5)
POLL_INTERVAL=5

# Port (Render sets this automatically — leave as 3000 for local dev)
PORT=3000
